# Required for AI-generated scans
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_SCAN_MODEL=openai/gpt-oss-120b

# Optional external web research. Without this, Scan uses first-party website evidence only.
EXA_API_KEY=

# Required before a public production launch for durable rate limiting and caching.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SCAN_RATE_LIMIT_SALT=

# Configure either a generic lead webhook or Resend email delivery.
SCAN_LEAD_WEBHOOK_URL=
SCAN_LEAD_WEBHOOK_TOKEN=
RESEND_API_KEY=
SCAN_FROM_EMAIL=FrontierGTM Scan <scan@frontiergtm.ai>
SCAN_LEAD_TO_EMAIL=ryan@frontiergtm.ai
